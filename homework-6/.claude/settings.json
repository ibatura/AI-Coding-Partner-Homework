{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "pipeline-status": {
      "command": "python",
      "args": [
        "mcp/server.py"
      ]
    }
  },
  "hooks": {
    "PrePush": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-coverage.sh",
            "description": "Verify test coverage is at least 80% before pushing"
          }
        ]
      }
    ]
  }
}